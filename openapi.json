            "title": "Chosen Strategy Id",
            "type": "string"
          },
          "overfitting_gap": {
            "title": "Overfitting Gap",
            "type": "number"
          },
          "random_entry_test": {
            "$ref": "#/components/schemas/PerformanceMetricsOut"
          },
          "test_metrics": {
