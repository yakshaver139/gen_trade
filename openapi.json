      "BacktestRequest": {
        "description": "Re-run a saved strategy on the run's original windows.\n\n``train_window``/``validation_window``/``test_window`` are intentionally\nNOT exposed yet \u2014 Phase 5 will add cross-asset / cross-window\nre-evaluation, with whitelisted asset registration. For now, the only\nsupported re-run is on the same windows the strategy came from.",
        "properties": {
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "strategy_id": {
            "title": "Strategy Id",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "strategy_id"
        ],
        "title": "BacktestRequest",
        "type": "object"
      },
      "BacktestResponse": {
        "properties": {
          "buy_and_hold_test": {
            "$ref": "#/components/schemas/PerformanceMetricsOut"
