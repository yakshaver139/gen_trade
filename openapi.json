          "validation_metrics",
          "test_metrics",
          "buy_and_hold_test",
          "random_entry_test",
          "overfitting_gap"
        ],
        "title": "BacktestResponse",
        "type": "object"
      },
      "CreateRunRequest": {
        "description": "Body of POST /runs.\n\n``asset`` must be a registered asset (see assets.py). ``population_size``\nis also the number of strategies the server generates.",
        "properties": {
          "asset": {
            "title": "Asset",
            "type": "string"
          },
          "elitism_count": {
            "default": 2,
            "maximum": 10.0,
            "minimum": 0.0,
            "title": "Elitism Count",
            "type": "integer"
          },
          "generations": {
            "default": 50,
            "maximum": 500.0,
            "minimum": 1.0,
            "title": "Generations",
            "type": "integer"
          },
          "population_size": {
            "default": 10,
            "maximum": 200.0,
            "minimum": 2.0,
            "title": "Population Size",
            "type": "integer"
          },
          "seed": {
            "default": 0,
            "title": "Seed",
            "type": "integer"
          },
          "selection_pressure": {
            "default": "tournament",
            "title": "Selection Pressure",
            "type": "string"
          },
          "slippage_bps": {
            "default": 1.0,
            "maximum": 1000.0,
            "minimum": 0.0,
            "title": "Slippage Bps",
            "type": "number"
          },
          "stop_loss_pct": {
            "default": 0.0075,
            "exclusiveMaximum": 1.0,
            "exclusiveMinimum": 0.0,
            "title": "Stop Loss Pct",
            "type": "number"
          },
          "taker_fee_bps": {
            "default": 10.0,
            "maximum": 1000.0,
            "minimum": 0.0,
            "title": "Taker Fee Bps",
            "type": "number"
          },
          "target_pct": {
            "default": 0.015,
            "exclusiveMaximum": 1.0,
            "exclusiveMinimum": 0.0,
            "title": "Target Pct",
            "type": "number"
          },
          "trade_window_bars": {
            "default": 96,
            "maximum": 10000.0,
            "minimum": 1.0,
            "title": "Trade Window Bars",
            "type": "integer"
          }
        },
        "required": [
          "asset"
        ],
        "title": "CreateRunRequest",
        "type": "object"
